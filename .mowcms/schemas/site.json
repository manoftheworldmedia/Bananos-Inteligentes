    {
      "name": "navigation",
      "label": "Navigation Menu",
      "icon": "menu",
      "kind": "single",
      "path": "content/navigation.json",
      "fields": [
        {
          "name": "items",
          "label": "Menu items (drag to reorder)",
          "type": "list",
          "min": 1,
          "of": {
            "type": "object",
            "fields": [
              {
                "name": "url",
                "label": "Link",
                "type": "url",
                "required": true
              },
              {
                "name": "newTab",
                "label": "Open in new tab",
                "type": "boolean",
                "default": false
              },
              {
                "name": "label_en",
                "label": "Label (English)",
                "type": "string",
                "required": true
              },
              {
                "name": "label_es",
                "label": "Label (Español)",
                "type": "string",
                "required": false
              }
            ]
          }
        }
      ]
    },
    {
      "name": "settings",
      "label": "Site Settings",
      "icon": "menu",
      "kind": "single",
      "path": "content/settings.json",
      "fields": [
        {
          "name": "email",
          "label": "Contact email",
          "type": "email"
        },
        {
          "name": "phone",
          "label": "Phone",
          "type": "string"
        },
        {
          "name": "social",
          "label": "Social links",
          "type": "list",
          "of": {
            "type": "object",
            "fields": [
              {
                "name": "platform",
                "label": "Platform",
                "type": "select",
                "options": [
                  "instagram",
                  "linkedin",
                  "x",
                  "youtube",
                  "tiktok",
                  "facebook"
                ],
                "required": true
              },
              {
                "name": "url",
                "label": "URL",
                "type": "url",
                "required": true
              }
            ]
          }
        },
        {
          "name": "shop_enabled",
          "label": "Enable shop",
          "type": "boolean",
          "default": false
        },
        {
          "name": "shop_currency",
          "label": "Default currency",
          "type": "select",
          "options": [
            "usd",
            "eur",
            "gbp",
            "cad",
            "aud"
          ],
          "default": "usd"
        },
        {
          "name": "en",
          "label": "English",
          "type": "object",
          "ui": {
            "group": "Languages"
          },
          "fields": [
